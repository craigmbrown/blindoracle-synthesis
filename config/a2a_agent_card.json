  "skills": [
    {
      "id": "create_forecast",
      "name": "Create Forecast Market",
      "description": "Create a new privacy-preserving information market with a question, deadline, and initial liquidity pool.",
      "category": "forecasts",
      "inputSchema": {
        "type": "object",
        "properties": {
          "question": { "type": "string", "maxLength": 500 },
          "deadline": { "type": "string", "format": "date-time" },
          "initial_liquidity_units": { "type": "integer", "minimum": 1000 },
          "resolution_source": { "type": "string", "default": "manual" },
          "payment_rail": { "type": "string", "enum": ["auto", "private", "stablecoin", "fiat"], "default": "auto" }
        },
        "required": ["question", "deadline", "initial_liquidity_units"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "market_id": { "type": "integer" },
          "question": { "type": "string" },
          "deadline": { "type": "string" },
          "commitment_address": { "type": "string" },
          "status": { "type": "string" },
          "tx_hash": { "type": "string" }
        }
      },
      "pricing": { "amount": "0.001", "currency": "USDC", "network": "base" }
    },
    {
      "id": "submit_position",
      "name": "Submit Forecast Position",
      "description": "Submit a privacy-preserving position on a forecast market. Uses commitment scheme (sha256(secret || position || amount)) ensuring zero identity linkage.",
      "category": "forecasts",
      "inputSchema": {
        "type": "object",
        "properties": {
          "market_id": { "type": "integer" },
          "position": { "type": "string", "enum": ["YES", "NO"] },
          "amount_units": { "type": "integer", "minimum": 100 },
          "private_tokens": { "type": "array", "items": { "type": "string" } },
          "payment_rail": { "type": "string", "default": "auto" }
        },
        "required": ["market_id", "position", "amount_units"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "position_id": { "type": "string" },
          "commitment": { "type": "string" },
          "market_id": { "type": "integer" },
          "amount_units": { "type": "integer" },
          "status": { "type": "string" },
          "tx_hash": { "type": "string" }
        }
      },
      "pricing": { "amount": "0.0005", "currency": "USDC", "network": "base", "notes": "Plus 0.1% of position amount" }
    },
    {
      "id": "resolve_forecast",
      "name": "Resolve Forecast Market",
      "description": "Resolve a forecast market with the final outcome. Winners receive private tokens for their payout amount.",
      "category": "forecasts",
      "inputSchema": {
        "type": "object",
        "properties": {
          "market_id": { "type": "integer" },
          "outcome": { "type": "string", "enum": ["YES", "NO"] },
          "evidence_url": { "type": "string", "format": "uri" }
        },
        "required": ["market_id", "outcome"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "market_id": { "type": "integer" },
          "outcome": { "type": "string" },
          "total_payout_units": { "type": "integer" },
          "winners_count": { "type": "integer" },
          "settlement_tx_hash": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "pricing": { "amount": "0.002", "currency": "USDC", "network": "base" }
    },
    {
      "id": "verify_credential",
      "name": "Verify Agent Credential",
      "description": "Verify an agent's credential portfolio and compute a 0.0-1.0 reputation score based on credential count, diversity, age, and witnesses.",
      "category": "identity",
      "inputSchema": {
        "type": "object",
        "properties": {
          "agent_pubkey": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "credential_id": { "type": "string", "format": "uuid" }
        },
        "required": ["agent_pubkey"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "agent_pubkey": { "type": "string" },
          "reputation_score": { "type": "number" },
          "active_credentials": { "type": "integer" },
          "proof_types": { "type": "array", "items": { "type": "string" } },
          "verification_result": { "type": "object" }
        }
      },
      "pricing": { "amount": "0.0002", "currency": "USDC", "network": "base" }
    },
    {
      "id": "mint_credential",
      "name": "Mint Agent Credential",
      "description": "Mint a verifiable credential badge (Proof of Presence, Participation, Belonging, or Witness) with anti-synthetic validation.",
      "category": "identity",
      "inputSchema": {
        "type": "object",
        "properties": {
          "agent_pubkey": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "proof_type": { "type": "string", "enum": ["presence", "participation", "belonging", "witness"] },
          "metadata": { "type": "object" },
          "witnesses": { "type": "array", "items": { "type": "string" } },
          "witness_signatures": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["agent_pubkey", "proof_type", "metadata"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "credential_id": { "type": "string" },
          "proof_type": { "type": "string" },
          "credential_kind": { "type": "integer" },
          "event_id": { "type": "string" },
          "status": { "type": "string" },
          "issued_at": { "type": "string" },
          "expires_at": { "type": ["string", "null"] }
        }
      },
      "pricing": { "amount": "0.001", "currency": "USDC", "network": "base" }
    },
    {
